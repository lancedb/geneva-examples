# --- Project-specific ---
# secrets + connection; copy from config-example.yaml
config.yaml
# local-mode on-disk Lance database (geneva.connect against a Path)
local_db/
# local MP4 download cache (ingest-videos)
video_cache/
# local PDF ingest directory (ingest-pdfs --pdf-dir default)
pdf_data/
# generated analysis reports (regenerated on demand; see reports/README.md)
reports/*.pdf
# fault/recovery demo data dirs (chunk-videos-faults / chunk-videos-recovery)
faults_demo_data/
recovery_demo_data/
# real-object-store fault harness artifacts (regenerated on demand)
fault_harness/*.json
fault_harness/*.pdf
# compiled LaTeX docs (the .tex is source; PDF is regenerated with tectonic)
docs/*.pdf

# UDF Studio sample data: keep the directory layout, ignore user-provided media.
studio_data/images/*
studio_data/videos/*
studio_data/audio/*
studio_data/pdfs/*
!studio_data/**/.gitkeep

# UDF Studio local LanceDB library of saved work-in-progress functions.
udf_library/

# --- Byte-compiled / optimized / DLL files ---
__pycache__/
*.py[cod]
*$py.class
*.so

# --- Packaging / distribution ---
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# requirements.txt exported by the CI dependency-audit job (uv.lock is the source of truth).
requirements.txt

