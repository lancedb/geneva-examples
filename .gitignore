.hypothesis/

# --- Jupyter / IPython ---
.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Environments / secrets ---
.env
.env.*
!.env.example

# --- Editors / IDEs ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS cruft ---
.DS_Store
Thumbs.db

